@page "/categorias"

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-0">Categorias</h2>
            <p class="text-muted">Categorias utilizadas para classificar demandas</p>
        </div>

        <div class="d-flex gap-2">
            <button class="btn btn-primary" @onclick="GoToCreateCategory">
                Nova Categoria
            </button>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="alert alert-info">
            Carregando categorias...
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger">
            @errorMessage
        </div>
    }
    else if (!categories.Any())
    {
        <div class="alert alert-warning">
            Nenhuma categoria encontrada.
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0">
            <div class="card-body">

                @if (!string.IsNullOrWhiteSpace(successMessage))
                {
                    <div class="alert alert-success">
                        @successMessage
                    </div>
                }

                <table class="table table-hover table-sm align-middle">
                    <thead>
                        <tr>
                            <th>Nome</th>
                            <th>Descrição</th>
                            <th>Status</th>
                            <th>Criada em</th>
                            <th>Ações</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var category in categories)
                        {
                            <tr>
                                <td>@category.Name</td>

                                <td>
                                    @(string.IsNullOrWhiteSpace(category.Description) ? "-" : category.Description)
                                </td>

                                <td>
                                    @if (category.IsActive)
                                    {
                                        <span class="badge bg-success">Ativa</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inativa</span>
                                    }
                                </td>

                                <td>@category.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>

                                <td>
                                    <div class="d-flex gap-1">
                                        <button class="btn btn-sm btn-outline-primary"
                                                @onclick="() => GoToEditCategory(category.Id)">
                                            Editar
                                        </button>

                                        <button class="btn btn-sm btn-outline-danger"
                                                disabled="@(!category.IsActive)"
                                                @onclick="() => InactivateCategory(category.Id)">
                                            Inativar
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

            </div>
        </div>
    }

</div>